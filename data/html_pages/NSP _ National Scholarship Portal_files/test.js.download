        function restartconnectionService() {
			if (flag == 0) {
				soc1.socket.connect();
				//flag = 1;
			}
        }

		/************************************************************************************************************************
			//-----------------------------------Start ASR service and send audio on the channel------------------------------//
		*************************************************************************************************************************/
		
        function startASRRivaService() {
            //optionsASR = {};

			//if connection is unsuccessful then connect again with ASR service
            if (flag == 0) {

                restartconnectionService();
            }
			if(!soc1.socket.connected)
				{
				alert("Due to some technical issue,we are not able to proceed with voice services.Kindly continue with text messages.");
				$('#img_phone_slash').click();
				return false;
				}
			
			
            audio_context = new AudioContext();
            var optionsASR = { model: "1", language: voice_lang, sampleRate: 44100 };
            //optionsASR.model = 1;
            //optionsASR.sampleRate = sampleRate;
            //optionsASR.language = language;
            // to start asr service 
            soc1.socket.emit('startasr', optionsASR);

            if (navigator.mediaDevices) {
                //console.log("getUserMedia supported.");
				
                navigator.mediaDevices
                    .getUserMedia({ audio: true, video: false })
                    .then((stream) => {
                        // Start ASR streaming
                        let audioInput = audio_context.createMediaStreamSource(stream);

                        // The stream-processor worklet node does the conversion from Float32 into 16-bit PCM
                        // Here code for pcm conversion added directly to web browser audio pipline as a module
                        audio_context.audioWorklet.addModule('streamProcessor.js')
                            .then(function () {
                                // taken audio in put from browser
                                var streamWorkletNode = new AudioWorkletNode(audio_context, 'stream-processor', {
                                    processorOptions: {
                                        sampleRate: 44100
                                    }
                                });
                                streamWorkletNode.port.onmessage = (event) => {
                                    // Send transformed PCM buffer to the server
                                    soc1.socket.emit('audio_in', event.data);
                                };

                                // connect stream to our worklet
                                audioInput.connect(streamWorkletNode);
                                // connect our worklet to the previous destination
                                streamWorkletNode.connect(audio_context.destination);
                            });
                        
                    })
					.catch((err)=>{
						alert("Media device not found!");
						$('#img_phone_slash').click();
					});
					
            } 
			else 
			{
            console.log("getUserMedia not supported on your browser!");
			}


 }
		
