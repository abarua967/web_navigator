class asrService {
    #privateField;
    constructor(protocol="wss", ip=window.location.hostname, port=8000) {
      this.#privateField="private";
      this.url=protocol+"://"+ip+":"+port
      this.socketio = io(this.url,{secure: true,
        'reconnection': true,
        'reconnectionDelay': 1000,
        'reconnectionAttempts': 4,
         pingInterval: 1000 * 60 * 5,
         pingTimeout: 1000 * 60 * 3
      });
      //this.callbackFunc=callback
      this.optionsASR = {model: 'none', language: 'hi'}
      this.audio_context = audio_context;
      this.socket = this.socketio.on('connect', function() {
        console.log('Socket connected to speech server');
		flag=1;
      });
      this.socket.on('lang_pair_resp', function(data){
        console.log("hi finally return")
        console.log(data);
      });
      this.socket.on('transcript', function(data) {
        console.log(data.transcript); // true
            //var d = JSON.parse(data);
            //if (data.is_final == true) {
            //    console.log(data.transcript);

            //}
            //$("#InputEnter").val(data['transcript']);
		if (data['is_final']){	
		$("#InputEnter").val($("#InputEnter").val()+data['transcript']);
        //$("#InputEnter").append('<div></div>');
    }
      
      });
      this.socket.on('connect_error', function(result) {
        console.log("connection issue");
		flag=0;
        //restartService=false;
      })
      this.socket.on('connect_failed', function(result) {
        console.log("connection issue");
		flag=0;
        //restartService=false;
      })
      this.socket.on('disconnect', function(result) {
        console.log("connection disconnect");
		flag=0;
        //restartService=false;
        
      })

    }
    age(x) {
        return x - this.year;

      }

 stopASRService() {
      //speechService= false;if(audio_context!=null)
		if(audio_context!=null)
			{
				if(audio_context.state!='closed')
				{
					audio_context.close();
				}
			}
      
            flag = 0;
      //this.audio_context.close();
      this.socket.emit('stop');
      this.socket.disconnect();
        
    }
}

