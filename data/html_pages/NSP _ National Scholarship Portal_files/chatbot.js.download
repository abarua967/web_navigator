/************************************************************************************************************************
 //---------Function to change value in input field when user clicks on options from drop down list---------------------//
*************************************************************************************************************************/
function changeInputfield(msg)
{
	var selmsg=msg;
	 var inputmsg=$("#InputEnter").val();
	// //alert(inputmsg);
	 inputmsg=inputmsg.trim();
	  var arr=inputmsg.split(" ");
	  var len=arr.length;
	  inputmsg=arr[len-1];
	 $("#InputEnter").val($("#InputEnter").val().replace(inputmsg,selmsg));
}

