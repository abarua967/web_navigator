			{
				$("#lbl_msg").css("display","block");
			}

			//check whether selected language is available in voice
			
			for(var key in voicelang)
			{
				if(botlang==key)
				{
					voice_lang=voicelang[key];
					flag1=1;
					break;
				}
			}
			flag1=1;
			//if not present then show another dialog to choose other lang or continue without voice
			if(flag1==0)
			{
				$('input[name="optradio"]:checked').attr("disabled",true);
				$('#myModal').modal('hide');
				$('#langModal').modal('show');
			}
			else
			{
				$('#myModal').modal('hide');
				showMessageDialog();
			}
			
			
		});

