var msg = "";
var contextName = "user";
var intentName = "";
var ChatCount = 0;
var startDate;
var box = null;
var count = 1;
var SessionID = null;
var chatLog = "";
var cdate = "";
var sid = "";
var did = "";
var appname = "nspChatBot";
var mode = "WebChatBot";
var df = "";
var status = "";
var lvalue = "";
var botlang="";
var multilangchatbot=1;    //if multilingual chatbot set value=1 else 0
//var voicelang=[{Name:"eng",flag:"1"},{Name:"hi",flag:"1"},{Name:"bn",flag:"1"},{Name:"mr",flag:"1"},{Name:"ta",flag:"1"},{Name:"te",flag:"1"},{Name:"kn",flag:"1"}]; //voice language available
var voicelang={"eng":"en","hindi":"hi","bengali":"bn","marathi":"mr","tamil":"ta","telugu":"te","kannada":"kn"};    //voice language available
var voice_lang="";
var panini_lang={"eng":"eng_Latn","hindi":"hin_Deva","bengali":"ben_Beng","marathi":"mar_Deva","tamil":"tam_Taml","telugu":"tel_Telu","kannada":"kan_Knda","gujarati":"guj_Gujr","malayalam":"mal_Mlym","assamese":"asm_Beng","nepali":"npi_Deva","oriya":"ory_Orya","punjabi":"pan_Guru"};
var matraFlg=1;  //for calling matra api
var trnsflg="0"; //for calling transliteration api
var mSent=0;

//---------------------- Initialize Chat Cont.---------------------------------------------------------------------------//

function CALLInvoke() {

    var srclang="";
	var targlang="eng_Latn";
	
	for(var key in panini_lang)
	{
		if(botlang==key)
		{
			srclang=panini_lang[key];
			break;
		}
	}

    var strtData = {
        MSG: msg,
        Sid: SessionID,
        IName: intentName,
        Count: ChatCount,
        app_name: appname,
        Mode: mode,
        dflag: df,
		lang:botlang,
		srclang:srclang,
		tarlang:targlang,
		trnsflg:trnsflg
    };
    var udata = JSON.stringify(strtData);
    $.ajax({
        url: "https://vani-hyd.nic.in/ChatBot3.0S/CallAPI.ashx", //CallAPI.ashx
        type: "POST",
        //contentType: "application/json; charset=utf-8",
        data: {
            ChatData: udata
        },
        success: function(data) {

            if (data != "") {

                if (data.RespMsg == 'exception') {
                    var str = "<img class=\"img-responsive\" src=\"https://vani-hyd.nic.in/nspBot/images/vani-gif.gif\" alt=\"Vani\"ṁ>\r\n" +
                        "           <div class=\"containermsg_vani\"> \r\n" +
                        "                 <p>Oops! Something went wrong. Please try again later.</p>\r\n" +
                        "                 <span class=\"time-right\">11:00</span>\r\n" +
                        "               </div>";
                    $(".Input_field").prop('disabled', true);
                    $(".Messages_list").append(str);
                } else {
					var res = data.RespMsg;
						//res=res+"<div class=\"show-read-more\">";
						res = res.replace(/\$\$/g, "<button type=\"button\" style=margin-bottom:1%; class=\"btn btn-primary\">");
                        //res = res.replace(/\$\$/g, "<button type=\"button\" style=margin-bottom:1%; class=\"btn btn-primary collapse show\" aria-labelledby=\"containermsg_vani\">");
                        res = res.replace(/\$\#/g, "</button>");
                        res = res.split("$");
						//res=res+"</div>";
						
					var intentlist=data.IntentList;
					
					//intentlist = intentlist.replace(/\$\$/g, "<button type=\"button\" style=margin-bottom:1%; class=\"btn btn-primary\">");
                        //res = res.replace(/\$\$/g, "<button type=\"button\" style=margin-bottom:1%; class=\"btn btn-primary collapse show\" aria-labelledby=\"containermsg_vani\">");
                        //intentlist = intentlist.replace(/\$\#/g, "</button>");
                        //intentlist = intentlist.split("$");
						
                    generate_message_vani(res[0], 'Vani');
					
					//generate_message_vani(intentlist, 'VaniIntent');
					
                    $(".Input_field").prop('disabled', false);
                    SessionID = data.SessionId;
                     //$("#logToSave").append("CallInvoke: RespMsg= ", data.RespMsg,"<br/>", "Action =", data.Action, "<br/>", "IntentName =", data.IntentName, "<br/>"); 
					

                    // generate_message_vani(data.RespMsg, 'Vani');
                    // $(".Input_field").prop('disabled', false);
                    // SessionID = data.SessionId;
                     //$("#logToSave").append("<strong>RespMsg = </strong>", data.RespMsg,"<br/>", "<strong>Action = </strong>", data.Action, "<br/>", "<strong>IntentName = </strong>", data.IntentName, "<br/><br/>");                                    
                }
            }
        },
        error: function(jqXHR, textStatus, errorThrown) {
            // alert("Error  " + errorThrown);
        }
    });
}



//---------------------- Send Chat to Dialogflow ---------------------------------------------------------------------------//

function messageSent(msg) {
    /* This function is called when user enter something. */
    var booltestRegex="";
    var regexT = new RegExp("^\\d{4}(0[1-9]|1[0-2])(0[1-9]|1[0-9]|2[0-9]|3[0-1])([0-9]{8})$");
    var filter = /^[0-9]+$/; /* To match only "Numeric Values" before and after characters */
    //Check the message enter by user against the given RegEx
    var chatReg = /^[a-zA-Z0-9]+[0-9a-zA-Z\\\/\!\(\)\-_\,\.\;\:\@\&\?\'\" )]*$/;
	//var chatReg = /^[a-zA-Z0-9]+[0-9a-zA-Z\,\.)]*$/;
	//var chatReg = /^[a-zA-Z0-9.,\s]+$/;
    //var chatReg = /^[0-9A-Za-z/\\\\]*$/;
	var srclang="";
	var targlang="eng_Latn";
	
	for(var key in panini_lang)
	{
		if(botlang==key)
		{
			srclang=panini_lang[key];
			break;
		}
	}
	if(botlang=="eng")
	{
		booltestRegex=chatReg.test(msg);
	}
	else
	{
		booltestRegex=true;
	}
    if (booltestRegex) {
		mSent=1;
        var strtData = {
            MSG: msg,
            Sid: SessionID,
            IName: intentName,
            Count: ChatCount,
            app_name: appname,
            Mode: mode,
            dflag: df,
			lang:botlang,
			srclang:srclang,
			tarlang:targlang,
			trnsflg:trnsflg
        };
        var udata = JSON.stringify(strtData);
        //$("#chat_div").chatbox("option", "boxManager").addMsg(contextName, msg); 
        $.ajax({
            type: "POST",
            url: "https://vani-hyd.nic.in/ChatBot3.0S/CallAPI.ashx", //CallAPI.ashx                                               
            // contentType: "application/json; charset=utf-8",
            data: {
                ChatData: udata
            },
            success: function(data) {

                SessionID = data.SessionId;
                RespMsg = data.RespMsg;
                action = data.Action;
                intentName = data.IntentName;
                contextName = data.Context;
                ChatCount = data.Count;
                status = data.Status;
                lvalue = data.Lvalue;
				
				RespMsg = RespMsg.replace(/\$\$/g, "<button type=\"button\" style=margin-bottom:1%; class=\"btn btn-primary\">");
                        //res = res.replace(/\$\$/g, "<button type=\"button\" style=margin-bottom:1%; class=\"btn btn-primary collapse show\" aria-labelledby=\"containermsg_vani\">");
                        RespMsg = RespMsg.replace(/\$\#/g, "</button>");
                        RespMsg = RespMsg.split("$");

                if (status == "dc") {
					//trnsflg="0";
                    generate_message_vani(RespMsg[0], 'Vani');
                    $(".Input_field").prop('disabled', true);
                }  
				// else if (status == "rm-pa") {
					// //trnsflg="1";
                    // generate_message_vani(RespMsg[0], 'Vani');
                    // $(".Input_field").prop('disabled', false);
				// }
				else if (status == "rmd") {
					//trnsflg="0";
                    generate_message_vani(RespMsg[0], 'Vani');
                    $(".Input_field").prop('disabled', true);
                } 
				else {
					//trnsflg="0";
                    generate_message_vani(RespMsg[0], 'Vani');
                    //generate_link_vani(RespMsg, 'more', 'www.google.com', 'profile-link');
                    //$(".Input_field").prop('disabled', true);                                 
                }

                 //$("#logToSave").append("<strong>User = </strong>", msg, "<br/>", "<strong>RespMsg = </strong> ", data.RespMsg, "<br/>", "<strong>Action = </strong>", data.Action, "<br/>", "<strong>IntentName = </strong>", data.IntentName, "<br/>","<strong>Ai Panini Msg = </strong>", data.UserMsg, "<br/><br/>");

                  // $("#logToSave").append(
                // "<div class=\"table-responsive\">          \n" + 
                // "  <table class=\"table\">\n" + 
                // "    <thead>\n" + 
                // "      <tr>\n" + 
                // "        <th>User</th>\n" + 
                // "        <th>RespMsg</th>\n" + 
                // "        <th>Action</th>\n" + 
                // "        <th>IntentName</th>\n" + 
                // "      </tr>\n" + 
                // "    </thead>\n" + 
                // "    <tbody>\n" + 
                // "      <tr>\n" + 
                // "        <td>"+msg+"</td>\n" + 
                // "        <td>"+data.RespMsg+"</td>\n" + 
                // "        <td>"+data.Action+"</td>\n" + 
                // "        <td>"+data.IntentName+"</td>\n" + 
                // "      </tr>\n" + 
                // "    </tbody>\n" + 
                // "  </table>\n" + 
                // "  </div>");

            },
            error: function(jqXHR, textStatus, errorThrown) {
                // alert("Error  " + errorThrown);
            }
        });

    }
	// else{
		// mSent=0;
		// alert("Only . and , characters are allowed.");
		
	// }
}

/************************************************************************************************************************
          //------------------------------This function will call transliteration API----------------------//
*************************************************************************************************************************/
function callMatraApi()
{
	
	var lang="";
	// var lang_dict={"eng":"eng",
	// "hindi":"hindi",
	// "assamese":"assamese",
	// "bengali":"bengali",
	// "gujarati":"gujarati",
	// "kannada":"kannada",
	// "malayalam":"malayalam",
	// "marathi":"marathi",
	// "nepali":"nepali",
	// "oriya":"oriya",
	// "punjabi":"punjabi",
	// "tamil":"tamil",
	// "telugu":"telugu"
// };

var lang_dict={"eng":"en",
	"hindi":"hi",
	"assamese":"as",
	"bengali":"bn",
	"gujarati":"gu",
	"kannada":"kn",
	"malayalam":"mr",
	"marathi":"ma",
	"nepali":"ne",
	"oriya":"or",
	"punjabi":"pa",
	"tamil":"ta",
	"telugu":"te"
};
	for(var key in lang_dict)
	{
		if(botlang==key)
		{
			lang=lang_dict[key];
			break;
		}
	}


	var input=$("#InputEnter").val();
	//alert(inputmsg);
	 var arr=input.split(" ");
	 var len=arr.length;
	 input=arr[len-1];
	 
	  var chatReg = /^[a-zA-Z0-9]+[0-9a-zA-Z\\\/\!\(\)\-_\,\.\;\:\@\&\?\'\" )]*$/;
	  //var chatReg = /^[a-zA-Z0-9.,@\s]+$/;
	  for(var i in arr)
	  {
		var inputmsg  =arr[i];
		 if(chatReg.test(inputmsg))
		 {
			$.ajax({
				url: "https://vani-hyd.nic.in/transliterationapi/callapi.ashx?inputmsg="+inputmsg+"&srclang="+"en"+"&tarlang="+lang, //CallAPI.ashx
				type: "Get",
				async:false,
				success: function(data) {
				
					$("#ddl_list").css("display","block");
					//data=JSON.parse(data);
					$("#ddl_list").empty();
					var closebtn="<button type=\"button\" id=\"ddl_list_close\" class=\"close rotate\">&times;</button></div>";
					$("#ddl_list").append(closebtn);
					for(var i=0;i<data.data.length&&i<5;i++)
					{				
						var opt="<a class=\"dropdown-item\" style=\"cursor:pointer\" onclick=\"changeInputfield(this.innerHTML);\">"+data.data[i]+"</a></br>";
						$("#ddl_list").append(opt);
					}
					$("#InputEnter").val($("#InputEnter").val().replace(inputmsg,data.data[0]));
				},
				error: function(jqXHR, textStatus, errorThrown) {
					 alert("Error  " + errorThrown);
				}
			});
		 }
		 // else{
				// alert("Only . , @ and , characters are allowed.");
			// }
	}
}





