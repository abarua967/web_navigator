	{
		idleTime=0;
	});
	$(this).keypress(function(e)
	{
		idleTime=0;
	});

/************************************************************************************************************************
 //---------Function to stop ASR service when idle---------------------//
*************************************************************************************************************************/
	function timerIncrement()
	{
		idleTime=idleTime+1;
		if(idleTime>10)
		{
			if(flag==1)
			{
				stopASRService();
			}
		}
	}

$("#ddl_list").css("display","none");


//When any key is pressed in input field 
$("#InputEnter").on("keypress",function(e)
{
	if(botlang!="eng" && matraFlg==1)
	{
		if(e.which==" " || e.which =="Spacebar"|| e.which =="32"|| e.which =="13")  //check for spacebar or enter key
		{
			var msg = $(".Input_field").val().trim();
			var arr=msg.split(" ");
			var len=arr.length;
			input=arr[len-1];
			const chatReg = /^[\p{L}\p{M}0-9.,@\s\u200C\u200D]+$/u;
			var booltestRegex=chatReg.test(input);
			if(booltestRegex)
			{
				callMatraApi();    //cal matra api to convert text into selected language
			}
			else{
				
				alert("Only . , @ and , characters are allowed.");
				var newString=[...input].filter(char => chatReg.test(char)).join('');
				$("#InputEnter").val($("#InputEnter").val().replace(input,newString));
			}
		}
		else
		{
			$("#ddl_list").css("display","none");   //hides options drop down list
		}
	}
});



