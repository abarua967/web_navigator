        }
      } */

      $(document).ready(function () {
        if (document.body.classList.contains('page-node-3614')) {
          var hamburgerMenu = document.querySelector('.hamburger-menu');
          var sidebarNavigation = document.querySelector('#block-gendercellnavigation');

          hamburgerMenu.addEventListener('click', function () {
            sidebarNavigation.classList.toggle('open');
            hamburgerMenu.classList.toggle('gc-toggled');
          });
        }



        if (document.body.classList.contains('page-node-4421')) {
          var hamburgerMenu = document.querySelector('.hamburger-menu');
          var sidebarNavigation = document.querySelector('#block-deanstrategycellnavigation');

          hamburgerMenu.addEventListener('click', function () {
            sidebarNavigation.classList.toggle('open');
            hamburgerMenu.classList.toggle('gc-toggled');
          });
        }



      });
    }
  };

})(jQuery, Drupal);
